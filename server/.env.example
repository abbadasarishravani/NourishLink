PORT=5000
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?appName=<app>
JWT_SECRET=change_me

# If your DNS blocks mongodb+srv SRV queries
DNS_SERVERS=8.8.8.8,1.1.1.1

# Twilio Verify (optional, for SMS login/registration verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

